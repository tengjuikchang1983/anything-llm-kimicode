# AnythingLLM with Kimi Code - Environment Configuration
# Copy this file to .env and fill in your values

###########################################
######## REQUIRED CONFIGURATION ###########
###########################################

# Kimi Code API Key (Required)
# Get your API key from: https://www.moonshot.cn/
KIMI_CODE_API_KEY=your-kimi-code-api-key-here

###########################################
######## OPTIONAL CONFIGURATION ###########
###########################################

# Kimi Code Model Preference (Optional)
# Default: kimi-for-coding
KIMI_CODE_MODEL_PREF=kimi-for-coding

# LLM Provider (Optional)
# Set to 'kimicode' to use Kimi Code as default
LLM_PROVIDER=kimicode

# Embedding Engine (Optional)
# Using built-in embedder (no external API needed)
EMBEDDING_ENGINE=native

# Vector Database (Optional)
# Using built-in LanceDB (no external DB needed)
VECTOR_DB=lancedb

###########################################
######## AUTHENTICATION SETTINGS ##########
###########################################

# JWT Secret (Optional - auto-generated if not set)
JWT_SECRET=your-jwt-secret-here

# JWT Expiry (Optional)
JWT_EXPIRY=30d

###########################################
######## OTHER SETTINGS ###################
###########################################

# Storage Directory (Optional)
STORAGE_DIR=/app/server/storage

# Disable Telemetry (Optional)
DISABLE_TELEMETRY=true
